{
	"compilerOptions": {
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"module": "commonjs",
		"target": "es6",
		"outDir": "out",
		"lib": [
			"es6"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"exclude": [
		"node_modules",
		".vscode-test",
		"server",
		"agent",
		"manifest.ts"
	]
}
