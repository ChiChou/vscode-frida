// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "watch",
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"dependsOn": [
				"agent",
				"webview-ui",
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "agent",
			"type": "npm",
			"script": "build",
			"isBackground": false,
			"presentation": {
				"reveal": "silent",
				"revealProblems": "onProblem",
				"close": false
			},
			"options": {
				"cwd": "agent"
			}
		},
		{
			"label": "webview-ui",
			"type": "npm",
			"script": "build",
			"isBackground": false,
			"presentation": {
				"reveal": "silent",
				"revealProblems": "onProblem",
				"close": false
			},
			"options": {
				"cwd": "webview-ui"
			}
		}
	]
}
